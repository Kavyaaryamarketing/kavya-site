---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const labPosts = (await getCollection('lab', (p) => !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// EDIT THESE three headline numbers as your site grows.
const stats = [
  { num: '—', label: 'Newsletter subscribers' },
  { num: '—', label: 'Monthly visitors' },
  { num: '—', label: 'Top traffic source' },
];

const badge = (r) => ({ won: 'won', lost: 'lost', inconclusive: 'inconclusive', ongoing: 'ongoing' }[r] || 'ongoing');
---
<Base title="Growth Lab — Kavya" description="Open marketing experiments, with the real numbers attached.">
  <section class="lab-hero">
    <div class="container">
      <span class="eyebrow" style="color:var(--rose);">Building in public</span>
      <h1>The Growth Lab</h1>
      <p class="lab-hero__sub">Every experiment I run to grow this site — the hypothesis, the spend, the result, and what I’d do differently. Including the ones that didn’t work.</p>
    </div>
  </section>

  <section class="container">
    <div class="stats">
      {stats.map((s) => (
        <div class="stat">
          <span class="stat__num">{s.num}</span>
          <span class="stat__label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="container lab-list">
    <h2>Experiment log</h2>
    {labPosts.length === 0 ? (
      <p class="muted">First experiment write-up coming soon. Add a Markdown file in <code>src/content/lab</code>.</p>
    ) : (
      <ul class="explist">
        {labPosts.map((p) => (
          <li class="exp reveal">
            <a href={`/lab/${p.slug}`}>
              <div class="exp__top">
                <span class={`badge badge--${badge(p.data.result)}`}>{p.data.result}</span>
                {p.data.metric && <span class="exp__metric">{p.data.metric}</span>}
                <span class="muted exp__date">{p.data.date.toLocaleDateString('en-IN', { month: 'short', year: 'numeric' })}</span>
              </div>
              <h3 class="exp__title">{p.data.title}</h3>
              <p class="exp__desc muted">{p.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>

<style>
  .lab-hero { background: var(--plum-deep); color: var(--cream); padding: clamp(3rem, 7vw, 5rem) 0; }
  .lab-hero h1 { color: var(--white); margin: 0.6rem 0; }
  .lab-hero__sub { color: #d8cfdc; max-width: 44rem; font-size: 1.15rem; }

  .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: -2.5rem 0 2rem; }
  .stat { background: var(--white); border: 1px solid var(--sand); border-radius: var(--radius); padding: 1.4rem; text-align: center; box-shadow: 0 8px 20px rgba(43,43,46,0.06); }
  .stat__num { display: block; font-family: var(--display); font-size: 2.4rem; color: var(--plum); line-height: 1; }
  .stat__label { display: block; margin-top: 0.5rem; font-size: 0.85rem; color: var(--muted); }
  @media (max-width: 720px) { .stats { grid-template-columns: 1fr; margin-top: -2rem; } }

  .lab-list { padding-block: 2rem 1rem; }
  .lab-list h2 { margin-bottom: 1.5rem; }
  .explist { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .exp a { display: block; text-decoration: none; color: inherit; background: var(--white); border: 1px solid var(--sand); border-radius: var(--radius); padding: 1.3rem; transition: 0.2s; }
  .exp a:hover { border-color: var(--rose); transform: translateY(-2px); }
  .exp__top { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.6rem; }
  .exp__metric { font-family: var(--display); font-weight: 600; color: var(--plum); }
  .exp__date { margin-left: auto; font-size: 0.85rem; }
  .exp__title { margin: 0 0 0.3rem; }
  .exp__desc { margin: 0; font-size: 0.95rem; }

  .badge { font-family: var(--body); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.2rem 0.6rem; border-radius: 5px; }
  .badge--won { background: #e4ece2; color: #4f6b4a; }
  .badge--lost { background: #f3e0e0; color: #9a4b4b; }
  .badge--inconclusive { background: var(--sand); color: var(--ink); }
  .badge--ongoing { background: #e6e1ec; color: var(--plum-deep); }
</style>
